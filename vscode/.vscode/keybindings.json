[
{ "key": "alt+shift+f12", "command": "workbench.action.toggleZenMode" },
  // ============================================================
  // CamelCase Navigation (maptz.camelcasenavigation)
  // Extensão: maptz.camelcasenavigation
  // ============================================================
  { "key": "ctrl+j",       "command": "maptz.camelcasenavigation.deleteCamelRightCommand", "when": "editorTextFocus" }, // maptz
  { "key": "ctrl+shift+l", "command": "maptz.camelcasenavigation.toggleCamelMode" }, // maptz

  // ============================================================
  // CamelCase Navigation (extension.*) – outra extensão complementar
  // ============================================================
  { "key": "alt+left",        "command": "extension.moveCamelLeftCommand",   "when": "editorTextFocus" },   // outra ext
  { "key": "alt+right",       "command": "extension.moveCamelRightCommand",  "when": "editorTextFocus" },   // outra ext
  { "key": "shift+alt+left",  "command": "extension.extendCamelLeftCommand", "when": "editorTextFocus" },   // outra ext
  { "key": "shift+alt+right", "command": "extension.extendCamelRightCommand","when": "editorTextFocus" },   // outra ext

  // ============================================================
  // Jumpy (wmaurer.vscode-jumpy)
  // ============================================================
  { "key": "escape",      "command": "extension.jumpy-exit", "when": "editorTextFocus && jumpy.isJumpyMode" }, // Jumpy
  { "key": "shift+enter", "command": "extension.jumpy-word", "when": "editorTextFocus" },                       // Jumpy

  // ============================================================
  // Bookmarks (alefragnani.bookmarks)
  // ============================================================
  { "key": "ctrl+0",         "command": "_bookmarks.jumpTo",          "args": { "index": 10 }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+1",         "command": "_bookmarks.jumpTo",          "args": { "index": 1  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+2",         "command": "_bookmarks.jumpTo",          "args": { "index": 2  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+3",         "command": "_bookmarks.jumpTo",          "args": { "index": 3  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+4",         "command": "_bookmarks.jumpTo",          "args": { "index": 4  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+5",         "command": "_bookmarks.jumpTo",          "args": { "index": 5  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+6",         "command": "_bookmarks.jumpTo",          "args": { "index": 6  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+7",         "command": "_bookmarks.jumpTo",          "args": { "index": 7  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+8",         "command": "_bookmarks.jumpTo",          "args": { "index": 8  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+9",         "command": "_bookmarks.jumpTo",          "args": { "index": 9  }, "when": "editorTextFocus" }, // Bookmarks
  { "key": "ctrl+f11",       "command": "bookmarks.toggleLabeled",    "when": "editorTextFocus" },                           // Bookmarks
  { "key": "ctrl+shift+0",   "command": "bookmarks.toggleLabeled",    "args": { "label": 10 }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+1",   "command": "bookmarks.toggleLabeled",    "args": { "label": 1  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+2",   "command": "bookmarks.toggleLabeled",    "args": { "label": 2  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+3",   "command": "bookmarks.toggleLabeled",    "args": { "label": 3  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+4",   "command": "bookmarks.toggleLabeled",    "args": { "label": 4  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+5",   "command": "bookmarks.toggleLabeled",    "args": { "label": 5  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+6",   "command": "bookmarks.toggleLabeled",    "args": { "label": 6  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+7",   "command": "bookmarks.toggleLabeled",    "args": { "label": 7  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+8",   "command": "bookmarks.toggleLabeled",    "args": { "label": 8  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+9",   "command": "bookmarks.toggleLabeled",    "args": { "label": 9  }, "when": "editorTextFocus" },  // Bookmarks
  { "key": "ctrl+shift+f11", "command": "bookmarks.listFromAllFiles", "when": "editorTextFocus" },                            // Bookmarks
  { "key": "f11",            "command": "bookmarks.toggle",           "args": { "type": "line" }, "when": "editorTextFocus" },// Bookmarks
  { "key": "shift+f11",      "command": "bookmarks.list",             "args": { "type": "line" }, "when": "editorTextFocus" },// Bookmarks
  { "key": "f2",             "command": "bookmarks.jumpToNext",       "when": "editorTextFocus" },                            // Bookmarks
  { "key": "shift+f2",       "command": "bookmarks.jumpToPrevious",   "when": "editorTextFocus" },                            // Bookmarks

  // ============================================================
  // Git (built-in) — remapeado para evitar AltGr no Windows
  // ============================================================
  { "key": "ctrl+k",           "command": "git.commitAll",            "when": "!inDebugMode && !terminalFocus" },
  { "key": "ctrl+shift+alt+k", "command": "git.pushTo",               "when": "!inDebugMode && !terminalFocus" }, // era ctrl+alt+k
  { "key": "ctrl+shift+alt+z", "command": "git.revertSelectedRanges", "when": "editorTextFocus && !editorReadonly" }, // era ctrl+alt+z
  { "key": "ctrl+t",           "command": "git.sync" },

  // ============================================================
  // Debug (built-in)
  // ============================================================
  { "key": "alt+5",         "command": "workbench.view.debug" },
  { "key": "shift+alt+f9",  "command": "workbench.view.debug" },

  { "key": "alt+f9",        "command": "editor.debug.action.runToCursor",           "when": "debugState == 'stopped'" },
  { "key": "ctrl+f8",       "command": "editor.debug.action.toggleBreakpoint",      "when": "debuggersAvailable && editorTextFocus" },
  { "key": "f7",            "command": "workbench.action.debug.stepInto",           "when": "debugState != 'inactive'" },
  { "key": "f8",            "command": "workbench.action.debug.stepOver",           "when": "debugState == 'stopped'" },
  { "key": "f9",            "command": "workbench.action.debug.continue",           "when": "inDebugMode" },
  { "key": "shift+f8",      "command": "workbench.action.debug.stepOut",            "when": "debugState == 'stopped'" },
  { "key": "shift+f9",      "command": "workbench.action.debug.run",                "when": "debuggersAvailable" },

  // ============================================================
  // Navegação / Arquivo / Editor (built-in)
  // ============================================================
  { "key": "alt+home",             "command": "breadcrumbs.focus", "when": "breadcrumbsPossible" },
  { "key": "ctrl+backquote",       "command": "workbench.action.selectTheme" },
  { "key": "ctrl+e",               "command": "workbench.action.openGlobalRecent" },
  { "key": "ctrl+pageup",          "command": "workbench.action.previousEditor" },
  { "key": "ctrl+pagedown",        "command": "workbench.action.nextEditor" },
  { "key": "pageup",               "command": "scrollPageUp",   "when": "textInputFocus" },
  { "key": "pagedown",             "command": "scrollPageDown", "when": "textInputFocus" },
  { "key": "shift+ctrl+backspace", "command": "workbench.action.navigateToLastEditLocation" },
  { "key": "shift+ctrl+f12",       "command": "workbench.action.maximizeEditor" },
  { "key": "shift+escape",         "command": "workbench.action.toggleSidebarVisibility" },
  { "key": "shift shift",          "command": "workbench.action.showCommands" },

  // Alternância entre editores via Alt (mantida)
  { "key": "alt+left",   "command": "workbench.action.previousEditor" },
  { "key": "alt+right",  "command": "workbench.action.nextEditor" },

  // ============================================================
  // Go To / Símbolos / Navegação de código (built-in)
  // ============================================================
  { "key": "ctrl+f12",         "command": "workbench.action.gotoSymbol", "when": "editorTextFocus" },
  { "key": "ctrl+g",           "command": "workbench.action.gotoLine" },
  { "key": "ctrl+shift+alt+n", "command": "workbench.action.gotoSymbol", "when": "editorTextFocus" },
  { "key": "f4",               "command": "editor.action.goToDeclaration", "when": "editorTextFocus" },
  { "key": "shift+ctrl+b",     "command": "editor.action.goToTypeDefinition", "when": "editorTextFocus" },
  { "key": "shift+ctrl+i",     "command": "editor.action.previewDeclaration" },

  // Implementação — remapeado para evitar AltGr (era ctrl+alt+b)
  { "key": "ctrl+shift+alt+b", "command": "editor.action.goToImplementation",
    "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor" },

  // ============================================================
  // Cursor / Inserção / Seleção (built-in)
  // ============================================================
  { "key": "alt+j",            "command": "editor.action.addSelectionToNextFindMatch", "when": "editorFocus" },
  { "key": "ctrl+alt+enter",   "command": "editor.action.insertLineBefore", "when": "editorTextFocus && !editorReadonly" }, // OK no Windows
  { "key": "ctrl+enter",       "command": "lineBreakInsert", "when": "textInputFocus && !editorReadonly" },
  { "key": "ctrl+w",           "command": "editor.action.smartSelect.grow",   "when": "editorTextFocus" },
  { "key": "shift+alt+down",   "command": "editor.action.moveLinesDownAction","when": "editorTextFocus && !editorReadonly" },
  { "key": "shift+alt+up",     "command": "editor.action.moveLinesUpAction",  "when": "editorTextFocus && !editorReadonly" },
  { "key": "shift+ctrl+alt+j", "command": "editor.action.selectHighlights",   "when": "editorFocus" },
  { "key": "shift+ctrl+w",     "command": "editor.action.smartSelect.shrink", "when": "editorTextFocus" },
  { "key": "shift+enter",      "command": "editor.action.insertLineAfter",    "when": "editorTextFocus && !editorReadonly" },

  // ============================================================
  // Folding / Unfolding (built-in)
  // ============================================================
  { "key": "ctrl+add",           "command": "editor.unfold",            "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+equals",        "command": "editor.unfold",            "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+minus",         "command": "editor.fold",              "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+subtract",      "command": "editor.fold",              "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+add",     "command": "editor.unfoldAll",         "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+equals",  "command": "editor.unfoldAll",         "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+minus",   "command": "editor.foldAll",           "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+subtract","command": "editor.foldAll",           "when": "editorTextFocus && foldingEnabled" },

  // Recursivo — remapeado para evitar AltGr (era ctrl+alt+…)
  { "key": "ctrl+shift+alt+add",      "command": "editor.unfoldRecursively", "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+alt+equals",   "command": "editor.unfoldRecursively", "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+alt+minus",    "command": "editor.foldRecursively",   "when": "editorTextFocus && foldingEnabled" },
  { "key": "ctrl+shift+alt+subtract", "command": "editor.foldRecursively",   "when": "editorTextFocus && foldingEnabled" },

  // ============================================================
  // Sugestões / Hover / Ações rápidas / Formatação (built-in)
  // ============================================================
  { "key": "alt+enter",      "command": "editor.action.quickFix",
    "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly" },
  { "key": "ctrl+alt+l",     "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor" },
  { "key": "ctrl+alt+o",     "command": "editor.action.organizeImports",
    "when": "editorTextFocus && !editorReadonly && supportedCodeAction =~ /(\\s|^)source\\.organizeImports\\b/" },
  { "key": "ctrl+q",         "command": "editor.action.showHover", "when": "editorTextFocus" },
  { "key": "ctrl+space",     "command": "editor.action.triggerSuggest",
    "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly" },
  { "key": "enter",          "command": "acceptSelectedSuggestion", "when": "editorTextFocus && suggestWidgetVisible" },

  // ============================================================
  // Find / Replace / Problemas (built-in)
  // ============================================================
  { "key": "ctrl+f1",       "command": "workbench.action.showErrorsWarnings", "when": "editorTextFocus" },
  { "key": "ctrl+l",        "command": "editor.action.nextMatchFindAction",     "when": "editorFocus" },
  { "key": "f3",            "command": "editor.action.nextMatchFindAction",     "when": "editorFocus" },
  { "key": "shift+ctrl+f",  "command": "workbench.action.findInFiles" },
  { "key": "shift+ctrl+l",  "command": "editor.action.previousMatchFindAction", "when": "editorFocus" },
  { "key": "shift+f3",      "command": "editor.action.previousMatchFindAction", "when": "editorFocus" },
  { "key": "shift+ctrl+r",  "command": "workbench.action.replaceInFiles" },

  // ============================================================
  // Referências e Call Hierarchy (ms-vscode.references-view / built-in)
  // ============================================================
  { "key": "alt+f7",       "command": "references-view.findReferences",     "when": "editorHasReferenceProvider" }, // ms-vscode.references-view
  { "key": "ctrl+alt+f7",  "command": "editor.action.referenceSearch.trigger",
    "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor" }, // built-in
  { "key": "ctrl+alt+h",   "command": "references-view.showCallHierarchy",  "when": "editorHasCallHierarchyProvider" }, // ms-vscode.references-view

  // ============================================================
  // Merge Conflicts (built-in)
  // ============================================================
  { "key": "ctrl+alt+a", "command": "merge-conflict.accept.incoming", "when": "isInDiffEditor" },
  { "key": "ctrl+alt+r", "command": "merge-conflict.accept.current",  "when": "isInDiffEditor" },

  // ============================================================
  // Tasks / Build (built-in)
  // ============================================================
  { "key": "ctrl+f9",   "command": "workbench.action.tasks.build" },
  { "key": "shift+f10", "command": "workbench.action.tasks.reRunTask" },

  // ============================================================
  // Files / Save (built-in)
  // ============================================================
  { "key": "ctrl+s", "command": "workbench.action.files.saveAll" },

  // ============================================================
  // UNBINDS — desabilitam atalhos padrão que conflitam com os seus
  // (mantidos para garantir que seu layout prevaleça)
  // ============================================================
  { "key": "alt+left",           "command": "-workbench.action.navigateBack" },
  { "key": "ctrl+enter",         "command": "-editor.action.insertLineAfter" },
  { "key": "ctrl+f12",           "command": "-editor.action.goToImplementation" },
  { "key": "ctrl+insert",        "command": "-editor.action.clipboardCopyAction" },
  { "key": "ctrl+p",             "command": "-workbench.action.quickOpen" },
  { "key": "ctrl+shift+d",       "command": "-workbench.view.debug" },
  { "key": "ctrl+shift+enter",   "command": "-editor.action.insertLineBefore" },
  { "key": "ctrl+space",         "command": "-editor.action.triggerSuggest" },
  { "key": "ctrl+t",             "command": "-workbench.action.showAllSymbols" },
  { "key": "ctrl+y",             "command": "-redo" },
  { "key": "ctrl+z",             "command": "-undo" },
  { "key": "ctrl+shift+z",       "command": "-redo" },
  { "key": "ctrl+c",             "command": "-editor.action.clipboardCopyAction" },
  { "key": "ctrl+v",             "command": "-editor.action.clipboardPasteAction" },
  { "key": "ctrl+x",             "command": "-editor.action.clipboardCutAction" },
  { "key": "shift+delete",       "command": "-editor.action.clipboardCutAction" },
  { "key": "shift+insert",       "command": "-editor.action.clipboardPasteAction" }
]